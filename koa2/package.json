{
  "name": "ai-api",
  "version": "1.0.0",
  "description": "AI Chat API - Node.js Koa2 JavaScript Implementation",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "prod": "NODE_ENV=production node src/app.js",
    "psql": "sudo -u postgres psql",
    "db:init": "NODE_ENV=production node src/config/sql/init-db.js",
    "health:check": "node scripts/test-db-health.js",
    "pm2:start": "pm2 start src/config/ecosystem.config.js --env production",
    "pm2:restart": "pm2 restart src/config/ecosystem.config.js --env production --update-env",
    "pm2:reload": "pm2 reload src/config/ecosystem.config.js --env production --update-env",
    "pm2:stop": "pm2 stop ai-api",
    "pm2:delete": "pm2 delete ai-api",
    "pm2:logs": "pm2 logs ai-api --lines 100 --nostream",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 list",
    "lint": "eslint src",
    "test": "echo \"运行特定测试：node tests/{module}.test.js\" && echo \"例如：node tests/api/auth.test.js\"",
    "test:auth": "node tests/api/auth.test.js",
    "test:user": "node tests/api/user.test.js",
    "test:db": "node tests/database/connection.test.js"
  },
  "dependencies": {
    "@koa/multer": "^4.0.0",
    "@koa/router": "^12.0.0",
    "archiver": "^7.0.1",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.2",
    "koa": "^2.14.2",
    "koa-bodyparser": "^4.4.1",
    "koa-static": "^5.0.0",
    "koa2-swagger-ui": "^5.10.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "svg-captcha": "^1.4.0",
    "swagger-jsdoc": "^6.2.8",
    "ua-parser-js": "^2.0.9",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "koa",
    "javascript",
    "ai",
    "api",
    "swagger"
  ],
  "author": "",
  "license": "MIT"
}
