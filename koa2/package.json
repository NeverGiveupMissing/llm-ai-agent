{
  "name": "ai-api",
  "version": "1.0.0",
  "description": "AI Chat API - Node.js Koa2 JavaScript Implementation",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon src/app.js",
    "start": "node src/app.js",
    "prod": "NODE_ENV=production node src/app.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:restart": "pm2 restart ecosystem.config.js --env production --update-env",
    "pm2:reload": "pm2 reload ecosystem.config.js --env production --update-env",
    "pm2:stop": "pm2 stop ai-api",
    "pm2:delete": "pm2 delete ai-api",
    "pm2:logs": "pm2 logs ai-api",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 list",
    "lint": "eslint src",
    "db:init": "node -e \"require('./src/config/init-db').initDatabase().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\""
  },
  "dependencies": {
    "@koa/router": "^12.0.0",
    "axios": "^1.6.2",
    "dayjs": "^1.11.10",
    "dotenv": "^16.3.1",
    "koa": "^2.14.2",
    "koa-bodyparser": "^4.4.1",
    "koa2-swagger-ui": "^5.10.0",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "koa",
    "javascript",
    "ai",
    "api",
    "swagger"
  ],
  "author": "",
  "license": "MIT"
}
